{
  "name": "@draftboard/mcp",
  "version": "1.0.0-alpha.1",
  "description": "Model Context Protocol server for the Draftboard Integration API — warm intros, paths, targets and connections.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "draftboard-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "smoke": "tsx src/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "draftboard",
    "sales",
    "warm-intros",
    "prospecting"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
